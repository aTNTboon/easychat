<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.MeetingMemberMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.model.MeetingMember">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="meeting_no" property="meetingNo" jdbcType="VARCHAR"/>
        <result column="user_id" property="userId" jdbcType="VARCHAR"/>
    </resultMap>

    <select id="selectByMeetingAndUser" resultMap="BaseResultMap">
        SELECT * FROM meeting_member
        WHERE meeting_no = #{meetingNo} AND user_id = #{userId}
    </select>

    <insert id="insert" parameterType="com.example.demo.model.MeetingMember">
        INSERT INTO meeting_member(meeting_no, user_id)
        VALUES(#{meetingNo}, #{userId})
    </insert>



    <delete id="delete">
        DELETE FROM meeting_member
        WHERE meeting_no = #{meetingNo} AND user_id = #{userId}
    </delete>

    <select id="selectByMeetingId" resultMap="BaseResultMap">
        SELECT * FROM meeting_member WHERE meeting_no = #{meetingNo}
    </select>
</mapper>