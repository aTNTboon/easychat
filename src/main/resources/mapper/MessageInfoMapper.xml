<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.MessageInfoMapper">

    <!-- 批量更新状态：根据 id 设置对应的 status，且仅更新原 status = 1 的记录 -->
    <update id="batchUpdateStatusToSended" parameterType="java.util.List">
        UPDATE message_info
        <set>
            status = CASE msg_id
            <foreach collection="list" item="item" separator=" ">
                WHEN #{item} THEN 1
            </foreach>
            END
        </set>
        WHERE msg_id IN
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
        AND status = 0
    </update>
    <update id="batchUpdateStatusToAccecped" parameterType="java.util.List">
        UPDATE message_info
        <set>
            status = CASE msg_id
            <foreach collection="list" item="item" separator=" ">
                WHEN #{item} THEN 1
            </foreach>
            END
        </set>
        WHERE msg_id IN
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
        AND status = 0
    </update>
</mapper>