<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.UserInfoMapper">
    <resultMap id="BaseResultMap" type="com.example.demo.model.UserInfo">
        <id column="user_id" property="userId" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="nick_name" property="nickName" jdbcType="VARCHAR"/>
        <result column="sex" property="sex" jdbcType="TINYINT"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="last_login_time" property="lastLoginTime" jdbcType="BIGINT"/>
        <result column="last_off_time" property="lastOffTime" jdbcType="BIGINT"/>
        <result column="meeting_no" property="meetingNo" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        user_id, email, nick_name, sex, password, status, create_time, last_login_time, last_off_time, meeting_no
    </sql>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_info
        WHERE user_id = #{userId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_info
    </select>

    <insert id="insert" parameterType="com.example.demo.model.UserInfo">
        INSERT INTO user_info
        (<include refid="Base_Column_List"/>)
        VALUES
        (#{userId}, #{email}, #{nickName}, #{sex}, #{password}, #{status},
         #{createTime}, #{lastLoginTime}, #{lastOffTime}, #{meetingNo})
    </insert>

    <update id="updateById" parameterType="com.example.demo.model.UserInfo">
        UPDATE user_info
        SET
            email = #{email},
            nick_name = #{nickName},
            sex = #{sex},
            password = #{password},
            status = #{status},
            create_time = #{createTime},
            last_login_time = #{lastLoginTime},
            last_off_time = #{lastOffTime},
            meeting_no = #{meetingNo}
        WHERE user_id = #{userId}
    </update>

    <delete id="deleteByUserId">
        DELETE FROM user_info
        WHERE user_id = #{userId}
    </delete>

    <select id="selectByEmail" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_info
        WHERE email = #{email}
    </select>

    <select id="selectByNickNameLike" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_info
        WHERE nick_name LIKE CONCAT('%', #{nickName}, '%')
    </select>
</mapper>