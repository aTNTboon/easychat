<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.ContactMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.model.Contact">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="contact_id" property="contactId"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, contact_id, created_at, updated_at
    </sql>



    <insert id="insert" parameterType="com.example.demo.model.Contact" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO contacts
        (user_id, contact_id, created_at, updated_at)
        VALUES
        (#{userId}, #{contactId}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.example.demo.model.Contact">
        UPDATE contacts
        SET
            user_id = #{userId},
            contact_id = #{contactId},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM contacts
        WHERE id = #{id}
    </delete>

<!--    <select id="selectAllByUserId" resultMap="BaseResultMap">-->
<!--        SELECT <include refid="Base_Column_List"/>-->
<!--        FROM contacts-->
<!--        WHERE user_id = #{userId}-->
<!--    </select>-->

    <select id="searchByNickname" resultMap="BaseResultMap">
        SELECT c.id, c.user_id, c.contact_id, c.created_at, c.updated_at
        FROM contacts c
        JOIN user_info u ON c.contact_id = u.id
        WHERE c.user_id = #{userId} AND u.nickname LIKE CONCAT('%', #{nickname}, '%')
    </select>
</mapper>